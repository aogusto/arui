{
  "name": "@aogusto/arui",
  "version": "0.1.1",
  "description": "Biblioteca de componentes React — Apple HIG + Tailwind 4 (shadcn-derived).",
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "tailwindcss",
    "shadcn",
    "apple-hig",
    "design-system",
    "radix",
    "component-library"
  ],
  "license": "MIT",
  "author": "Augusto Ribeiro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aogusto/arui.git"
  },
  "homepage": "https://arui.vercel.app",
  "bugs": "https://github.com/aogusto/arui/issues",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "prepack": "npm run build",
    "build:preview": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "prepublishOnly": "npm run typecheck && npm run build",
    "build:manifest": "tsx scripts/build-manifest.ts"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "react-hook-form": "^7",
    "tailwindcss": "^4"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.170.18",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.75.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.0.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "zod": "^4.4.3"
  }
}
